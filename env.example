# ═══════════════════════════════════════════════════════════════
# .env.example — TaskFlow
# Copy to .env and adjust values (never commit .env to git!)
# ═══════════════════════════════════════════════════════════════

# Application
NODE_ENV=production
PORT=3000

# Database (path inside the container — uses Docker volume)
DATABASE_URL=/app/data/taskflow.db

# Seed behavior
# true  = seed the database on first startup if it's empty
# false = never auto-seed (useful after first deploy)
SEED_ON_FIRST_RUN=true
